<%
const typeName = entity.charAt(0).toUpperCase() + entity.slice(1);
const className = typeName + 's';
const collectionName = entity.toLowerCase() + 's';

const fieldNames = fields.map(f => f.name);
%>

<%_ if (type === 'esm') { _%>
import { getDb } from '../db/client';
<%_ if (language === 'typescript') { _%>
import { <%= typeName %>, <%= typeName %>Payload } from '../types/<%= entity %>';
<%_ } _%>
<%_ } else { _%>
const { getDb } = require('../db/client');
<%_ } _%>

class <%= className %> {
  static collection() {
    return getDb().collection('<%= collectionName %>');
  }

  static async insert(
    id<%_ if (language === 'typescript') { _%>: string<%_ } _%>,
    payload<%_ if (language === 'typescript') { _%>: <%= typeName %>Payload<%_ } _%>
  )<%_ if (language === 'typescript') { _%>: Promise<string><%_ } _%> {
    const doc = {
      id,
<%_ for (const f of fieldNames) { _%>
      <%= f %>: payload.<%= f %>,
<%_ } _%>
      createdAt: new Date().toISOString(),
      updatedAt: new Date().toISOString()
    };

    await this.collection().insertOne(doc);
    return id;
  }

  static async update(
    id<%_ if (language === 'typescript') { _%>: string<%_ } _%>,
    payload<%_ if (language === 'typescript') { _%>: <%= typeName %>Payload<%_ } _%>
  )<%_ if (language === 'typescript') { _%>: Promise<string><%_ } _%> {
    const updateDoc = {
      $set: {
<%_ for (const f of fieldNames) { _%>
        <%= f %>: payload.<%= f %>,
<%_ } _%>
        updatedAt: new Date().toISOString()
      }
    };

    await this.collection().updateOne({ id }, updateDoc);
    return id;
  }

  static async delete(
    id<%_ if (language === 'typescript') { _%>: string<%_ } _%>
  )<%_ if (language === 'typescript') { _%>: Promise<void><%_ } _%> {
    await this.collection().deleteOne({ id });
  }

  static async get(
    id<%_ if (language === 'typescript') { _%>: string<%_ } _%>
  )<%_ if (language === 'typescript') { _%>: Promise<<%= typeName %> | null><%_ } _%> {
    const doc = await this.collection().findOne({ id });
    return doc || null;
  }

  static async list()<%_ if (language === 'typescript') { _%>: Promise<<%= typeName %>[]><%_ } _%> {
    const docs = await this.collection().find().toArray();
    return docs;
  }
}

<%_ if (type === 'esm') { _%>
export { <%= className %> };
<%_ } else { _%>
module.exports = { <%= className %> };
<%_ } _%>