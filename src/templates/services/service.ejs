<%
const typeName = api.charAt(0).toUpperCase() + api.slice(1);
const className = typeName + 'Service';
const modelName = typeName + 's';
%>

<%_ if (type === 'esm') { _%>
import { v4 as uuidv4 } from 'uuid';
import { <%= modelName %> } from '../models/<%= api %>';
<%_ if (language === 'typescript') { _%>
import { <%= typeName %>, <%= typeName %>Payload } from '../types/<%= api %>';
<%_ } _%>
<%_ } else { _%>
const { v4: uuidv4 } = require('uuid');
const { <%= modelName %> } = require('../models/<%= api %>');
<%_ } _%>

class <%= className %> {
  static async create(
    payload<%_ if (language === 'typescript') { _%>: <%= typeName %>Payload<%_ } _%>
  )<%_ if (language === 'typescript') { _%>: Promise<string><%_ } _%> {
    const id = uuidv4();
    await <%= modelName %>.insert(id, payload);
    return id;
  }

  static async update(
    id<%_ if (language === 'typescript') { _%>: string<%_ } _%>,
    payload<%_ if (language === 'typescript') { _%>: <%= typeName %>Payload<%_ } _%>
  )<%_ if (language === 'typescript') { _%>: Promise<string><%_ } _%> {
    const existing = await <%= modelName %>.get(id);
    if (!existing) {
      throw new Error('<%= typeName %> with provided id does not exist');
    }

    await <%= modelName %>.update(id, payload);
    return id;
  }

  static async get(
    id<%_ if (language === 'typescript') { _%>: string<%_ } _%>
  )<%_ if (language === 'typescript') { _%>: Promise<<%= typeName %>><%_ } _%> {
    const data = await <%= modelName %>.get(id);
    if (!data) {
      throw new Error('<%= typeName %> does not exist');
    }
    return data;
  }

  static async list()<%_ if (language === 'typescript') { _%>: Promise<<%= typeName %>[]><%_ } _%> {
    return <%= modelName %>.list();
  }

  static async delete(
    id<%_ if (language === 'typescript') { _%>: string<%_ } _%>
  )<%_ if (language === 'typescript') { _%>: Promise<string><%_ } _%> {
    const existing = await <%= modelName %>.get(id);
    if (!existing) {
      throw new Error('<%= typeName %> does not exist');
    }

    await <%= modelName %>.delete(id);
    return id;
  }
}

<%_ if (type === 'esm') { _%>
export { <%= className %> };
<%_ } else { _%>
module.exports = { <%= className %> };
<%_ } _%>