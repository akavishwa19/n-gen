<%_ if (type === 'esm') { _%>
import express from 'express';
import { create, update, remove, get, list } from '../controllers/<%= api %>';
<%_ } else { _%>
const express = require('express');
const { create, update, remove, get, list } = require('../controllers/<%= api %>');
<%_ } _%>

const router = express.Router();

router.post('/', create);
router.put('/:id', update);
router.delete('/:id', remove);
router.get('/:id', get);
router.get('/list', list);

<%_ if (type === 'esm') { _%>
export default router;
<%_ } else { _%>
module.exports = router;
<%_ } _%>