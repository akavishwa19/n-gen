    return res.status(201).json({ success: true, data: { id } });
  } catch (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) {
    <%= logError %>({ error }, 'Failed to create <%= entity %>');
    return res.status(500).json({ success: false, message: 'Failed to create <%= entity %>' });
  }
};

const update = async (req<%_ if (language === 'typescript') { _%>: Request<%_ } _%>, res<%_ if (language === 'typescript') { _%>: Response<%_ } _%>) => {
  try {
    const { id } = req.params;

    if (!id) {
      return res.status(400).json({ success: false, message: 'id is required' });
    }

    const updatedId = await <%= entityName %>Service.update(id, req.body);
    <%= logInfo %>('Updated <%= entity %> with id:', updatedId);
    return res.status(200).json({ success: true, data: { id: updatedId } });
  } catch (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) {
    <%= logError %>({ error }, 'Failed to update <%= entity %>');
