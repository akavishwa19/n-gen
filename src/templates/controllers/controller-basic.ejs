<%
const entityName = entity.charAt(0).toUpperCase() + entity.slice(1);
const className = entityName + 's';
%>

<%_ if (type === 'esm') { _%>
import { <%= className %> } from '../models/<%= entity %>';
import { v4 as uuidv4 } from 'uuid';
<%_ if (logger === 'yes') { _%>
import logger from '../utils/logger';
<%_ } _%>
<%_ if (language === 'typescript') { _%>
import { Request, Response } from 'express';
<%_ } _%>
<%_ } else { _%>
const { <%= className %> } = require('../models/<%= entity %>');
const { v4: uuidv4 } = require('uuid');
<%_ if (logger === 'yes') { _%>
const logger = require('../utils/logger');
<%_ } _%>
<%_ } _%>

<%
const logError = logger === 'yes' ? 'logger.error' : 'console.error';
const logInfo = logger === 'yes' ? 'logger.info' : 'console.log';
%>

const create = async (req<%_ if (language === 'typescript') { _%>: Request<%_ } _%>, res<%_ if (language === 'typescript') { _%>: Response<%_ } _%>) => {
  try {
    const id = uuidv4();
    await <%= className %>.insert(id, req.body);
    <%= logInfo %>('Created <%= entity %> with id:', id);
    return res.status(201).json({ success: true, data: { id } });
  } catch (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) {
    <%= logError %>({ error }, 'Failed to create <%= entity %>');
    return res.status(500).json({ success: false, message: 'Failed to create <%= entity %>' });
  }
};

const update = async (req<%_ if (language === 'typescript') { _%>: Request<%_ } _%>, res<%_ if (language === 'typescript') { _%>: Response<%_ } _%>) => {
  try {
    const { id } = req.params;

    if (!id) {
      return res.status(400).json({ success: false, message: 'id is required' });
    }

    const existing = await <%= className %>.get(id);
    if (!existing) {
      return res.status(404).json({ success: false, message: '<%= entityName %> not found' });
    }

    await <%= className %>.update(id, req.body);
    <%= logInfo %>('Updated <%= entity %> with id:', id);
    return res.status(200).json({ success: true, data: { id } });
  } catch (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) {
    <%= logError %>({ error }, 'Failed to update <%= entity %>');
    return res.status(500).json({ success: false, message: 'Failed to update <%= entity %>' });
  }
};

const get = async (req<%_ if (language === 'typescript') { _%>: Request<%_ } _%>, res<%_ if (language === 'typescript') { _%>: Response<%_ } _%>) => {
  try {
    const { id } = req.params;

    if (!id) {
      return res.status(400).json({ success: false, message: 'id is required' });
    }

    const data = await <%= className %>.get(id);

    if (!data) {
      return res.status(404).json({ success: false, message: '<%= entityName %> not found' });
    }

    return res.status(200).json({ success: true, data });
  } catch (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) {
    <%= logError %>({ error }, 'Failed to fetch <%= entity %>');
    return res.status(500).json({ success: false, message: 'Failed to fetch <%= entity %>' });
  }
};

const list = async (_req<%_ if (language === 'typescript') { _%>: Request<%_ } _%>, res<%_ if (language === 'typescript') { _%>: Response<%_ } _%>) => {
  try {
    const data = await <%= className %>.list();
    return res.status(200).json({ success: true, data });
  } catch (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) {
    <%= logError %>({ error }, 'Failed to list <%= entity %>');
    return res.status(500).json({ success: false, message: 'Failed to list <%= entity %>' });
  }
};

const remove = async (req<%_ if (language === 'typescript') { _%>: Request<%_ } _%>, res<%_ if (language === 'typescript') { _%>: Response<%_ } _%>) => {
  try {
    const { id } = req.params;

    if (!id) {
      return res.status(400).json({ success: false, message: 'id is required' });
    }

    const existing = await <%= className %>.get(id);
    if (!existing) {
      return res.status(404).json({ success: false, message: '<%= entityName %> not found' });
    }

    await <%= className %>.delete(id);
    <%= logInfo %>('Deleted <%= entity %> with id:', id);
    return res.status(200).json({ success: true, data: { id } });
  } catch (error<%_ if (language === 'typescript') { _%>: unknown<%_ } _%>) {
    <%= logError %>({ error }, 'Failed to delete <%= entity %>');
    return res.status(500).json({ success: false, message: 'Failed to delete <%= entity %>' });
  }
};

<%_ if (type === 'esm') { _%>
export { create, update, get, list, remove };
<%_ } else { _%>
module.exports = { create, update, get, list, remove };
<%_ } _%>