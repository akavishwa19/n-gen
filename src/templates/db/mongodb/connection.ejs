<% if(type==='esm') { %>
import { MongoClient<% if(language==='typescript') { %>, Db<% } %> } from 'mongodb';
<% if (logger === 'yes') { %>
import logger from '../utils/logger';
<% } %>
<% } else { %>
const { MongoClient } = require('mongodb');
<% if (logger === 'yes') { %>
const logger = require('../utils/logger');
<% } %>
<% } %>

<%
const logError = logger === 'yes' ? 'logger.error' : 'console.error';
const logInfo = logger === 'yes' ? 'logger.info' : 'console.log';
%>

const uri = process.env.MONGO_URI;

const client = new MongoClient(uri);

let db <% if(language==='typescript') { %>: Db <% } %>;

const connectToDb = async () <% if (language === 'typescript') { %>: Promise<void><% } %> => {
  try {
    await client.connect();
    db = client.db(process.env.DB_NAME);
    <%= logInfo %>('connected to mongodb successfully');
  } catch (error <% if(language==='typescript') { %>: unknown<% } %>) {
    <%= logError %>({ error }, 'error connecting to mongodb');
    throw new Error('error connecting to mongodb');
  }
};

const getDb = () <% if (language === 'typescript') { %>: Db<% } %> => {
  if (!db) {
    throw new Error('database not initialized. Call connectToDb first.');
  }
  return db;
};

<% if(type==='esm') { %>
export { client, connectToDb, getDb };
<% } else { %>
module.exports = { client, connectToDb, getDb };
<% } %>