<%
const toCamel = (str) => str.charAt(0).toLowerCase() + str.slice(1);
const toPlural = (str) => str + 's';
%>

<%_ if (type === 'esm') { _%>
import express from 'express';
<%_ for (const api of apis) { _%>
import <%= toCamel(api) %>Router from './<%= api %>';
<%_ } _%>
<%_ } else { _%>
const express = require('express');
<%_ for (const api of apis) { _%>
const <%= toCamel(api) %>Router = require('./<%= api %>');
<%_ } _%>
<%_ } _%>

const router = express.Router();

<%_ for (const api of apis) { _%>
router.use('/<%= toPlural(api) %>', <%= toCamel(api) %>Router);
<%_ } _%>

<%_ if (type === 'esm') { _%>
export default router;
<%_ } else { _%>
module.exports = router;
<%_ } _%>